{
  "schema_version": 1,
  "name": "high_quality",
  "label_th": "High Quality — รายละเอียดสูง",
  "description": "อิงค่า alignment สูงของ 28-VSD แต่ใช้ depth maps สำหรับ production; ใช้ทรัพยากรมากและต้องยืนยันก่อนเริ่ม",
  "align": {
    "downscale": 1,
    "generic_preselection": true,
    "reference_preselection": false,
    "keypoint_limit": 80000,
    "tiepoint_limit": 10000,
    "guided_matching": true
  },
  "depth_maps": {"enabled": true, "downscale": 2, "filter_mode": "mild"},
  "dem": {"source": "depth_maps"},
  "orthomosaic": {"surface": "elevation", "fill_holes": true},
  "hardware": {"cpu_enabled": true, "gpu_mode": "auto"},
  "qa": {"alignment_pass_ratio": 0.85, "alignment_warning_ratio": 0.6},
  "odm_args": ["--feature-quality", "high", "--orthophoto-resolution", "2"]
}
